# Copy to `.llm.env` (gitignored) and fill in. The seed generator reads this.
# Pick ONE provider below.

CANONCITE_LLM_PROVIDER=openai

# --- Together AI ---
CANONCITE_LLM_BASE_URL=https://api.together.xyz/v1
CANONCITE_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
CANONCITE_LLM_API_KEY=PASTE_KEY_HERE

# --- Groq (alt) ---
# CANONCITE_LLM_BASE_URL=https://api.groq.com/openai/v1
# CANONCITE_LLM_MODEL=llama-3.3-70b-versatile

# --- OpenRouter (alt) ---
# CANONCITE_LLM_BASE_URL=https://openrouter.ai/api/v1
# CANONCITE_LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# --- Fireworks (alt) ---
# CANONCITE_LLM_BASE_URL=https://api.fireworks.ai/inference/v1
# CANONCITE_LLM_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# --- Local/remote Ollama instead (no key needed) ---
# CANONCITE_LLM_PROVIDER=ollama
# CANONCITE_LLM_MODEL=llama3.1:8b
